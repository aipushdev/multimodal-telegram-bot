BOT_TOKEN=токен_от_BotFather

# БД (для локального запуска без docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5441/psychoai

# LLM provider: yandex (default)
LLM_PROVIDER=yandex
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_MODEL=yandexgpt-lite

# Image generation provider: gemini (default)
IMAGE_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=imagen-4.0-fast-generate-001
GEMINI_LLM_MODEL=gemini-2.0-flash      # модель для чата (если LLM_PROVIDER=gemini)
GEMINI_VISION_MODEL=gemini-2.0-flash   # модель для распознавания фото/рукописей

# STT provider: whisper (default, поднимается в docker compose)
STT_PROVIDER=whisper
WHISPER_URL=http://whisper:9000
WHISPER_MODEL=medium   # tiny | base | small | medium | large-v3

# Bot mode: polling (default) | webhook (для VPS)
MODE=polling
WEBHOOK_URL=https://yourdomain.com
WEBHOOK_PORT=8443

ADMIN_USER_ID=0
